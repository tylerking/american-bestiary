# MongoDB connection
# Required by the SvelteKit app (src/lib/server/db.ts) and the seed script (scripts/seed.ts).
# Use a local mongod instance or an Atlas cluster — the app reads from the `bestiary` database and `creatures` collection.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
